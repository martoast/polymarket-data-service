APP_NAME=polymarket-data
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
APP_PORT=8001
APP_FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

WWWGROUP=1000
WWWUSER=1000

# Database (PostgreSQL + TimescaleDB)
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=polymarket
DB_USERNAME=sail
DB_PASSWORD=password

FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1

# Stripe
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_BUILDER_PRICE_ID=price_
STRIPE_PRO_PRICE_ID=price_

# Polymarket / Gamma API
GAMMA_API_BASE=https://gamma-api.polymarket.com
RESOLUTION_DELAY_MINUTES=5

# SQLite recorder file (for ingest:sync command)
SQLITE_DB_PATH=./data
RECORDER_SQLITE_FILE=/var/data/polymarket.db

# Path to historical session JSONL recordings (for backfill:recordings command)
# RECORDINGS_PATH=/Volumes/Seagate/polymarket/data/recordings

# Stripe webhook signing secret (get from Stripe dashboard → Webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_

# Mail (Mailgun)
MAIL_MAILER=mailgun
MAILGUN_DOMAIN=mg.fullstacklabs.org
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net
MAIL_FROM_ADDRESS=noreply@fullstacklabs.org
MAIL_FROM_NAME="${APP_NAME}"
